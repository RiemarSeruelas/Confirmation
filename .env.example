# Server
PORT=5178
NODE_ENV=development

# Option 1: use DATABASE_URL
# DATABASE_URL=postgres://postgres:your_password@localhost:5432/confirmation_test_db

# Option 2: use separate PostgreSQL values
PGHOST=localhost
PGPORT=5432
PGDATABASE=confirmation_test_db
PGUSER=postgres
PGPASSWORD=your_password

# setup-db uses this existing PostgreSQL database and only creates/updates app tables.

# Set true only if your PostgreSQL needs SSL
PGSSL=false

# AI Face Recognition Workstation
AI_FACE_BASE_URL=http://10.156.119.146:5005
AI_FACE_REGISTER_PATH=/register
AI_FACE_SEARCH_PATH=/search

# Face AI expects JSON body with img as a data URL.
# Search body: model settings + img
# Register body: name + identity + person_id + model settings + img
AI_FACE_IMAGE_FIELD=img
AI_FACE_NAME_FIELD=name
AI_FACE_TIMEOUT_MS=30000
AI_FACE_PAYLOAD_MODE=json
AI_FACE_MODEL_NAME=SFace
AI_FACE_DETECTOR_BACKEND=yunet
AI_FACE_ALIGN=true
AI_FACE_L2_NORMALIZE=true
AI_FACE_DISTANCE_METRIC=cosine
AI_FACE_SEARCH_METHOD=exact
