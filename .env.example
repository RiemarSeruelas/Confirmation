# Public address: http://YOUR-PC-IP:5058
PUBLIC_PORT=5058

# PostgreSQL
# Keep the values from your current working .env file.
PGHOST=10.156.119.155
PGPORT=5432
PGDATABASE=mydatabase
PGUSER=myuser
PGPASSWORD=replace_with_your_password
PGSSL=false

# Face recognition service
AI_FACE_BASE_URL=http://10.156.119.146:5005
AI_FACE_REGISTER_PATH=/register
AI_FACE_SEARCH_PATH=/search
AI_FACE_TIMEOUT_MS=30000
AI_FACE_MODEL_NAME=SFace
AI_FACE_DETECTOR_BACKEND=yunet
AI_FACE_ALIGN=true
AI_FACE_L2_NORMALIZE=true
AI_FACE_DISTANCE_METRIC=cosine
AI_FACE_SEARCH_METHOD=exact

# Image-reading service (Ollama-compatible /api/generate)
AI_IMAGE_BASE_URL=http://10.156.119.146:11436
AI_IMAGE_PATH=/api/generate
AI_IMAGE_MODEL=qwen3-vl
AI_IMAGE_TIMEOUT_MS=60000
MAX_PROOF_IMAGE_BYTES=6291456
