# Server
PORT=5178
NODE_ENV=development

# Option 1: use DATABASE_URL
# DATABASE_URL=postgres://postgres:your_password@localhost:5432/your_database

# Option 2: use separate PostgreSQL values
PGHOST=localhost
PGPORT=5432
PGDATABASE=your_database
PGUSER=postgres
PGPASSWORD=your_password

# Set true only if your PostgreSQL needs SSL
PGSSL=false
