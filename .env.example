# Server
PORT=5178
NODE_ENV=development

# Option 1: use DATABASE_URL
# setup-db will create the database name inside this URL if it does not exist.
# DATABASE_URL=postgres://postgres:your_password@localhost:5432/confirmation_test_db

# Option 2: use separate PostgreSQL values
PGHOST=localhost
PGPORT=5432
PGDATABASE=confirmation_test_db
PGUSER=postgres
PGPASSWORD=your_password

# setup-db connects here first so it can create PGDATABASE if missing.
# Usually keep this as postgres.
PGMAINTENANCE_DATABASE=postgres

# Set true only if your PostgreSQL needs SSL
PGSSL=false

# AI Face Recognition Workstation
AI_FACE_BASE_URL=http://10.156.119.146:5005
AI_FACE_REGISTER_PATH=/register
AI_FACE_SEARCH_PATH=/search

# Most Flask/OpenCV face APIs expect multipart/form-data with a file field.
# Try file first. If your AI app expects image, change this to image.
AI_FACE_IMAGE_FIELD=file
AI_FACE_NAME_FIELD=name
AI_FACE_TIMEOUT_MS=30000
