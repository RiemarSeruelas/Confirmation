{
  "name": "confirmation-test-db-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n DOCLING,SERVER,CLIENT -c yellow,cyan,magenta \"python -u docling_service.py\" \"node --watch server.js\" \"vite\"",
    "dev:docling": "python -u docling_service.py",
    "dev:server": "node --watch server.js",
    "dev:client": "vite",
    "build": "vite build",
    "setup-db": "node makeDb.js",
    "start": "node server.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.4"
  }
}
